# Shared
ECODROP_ENV=development

# Frontend
VITE_API_BASE_URL=http://localhost:8000
VITE_AUTO_DEMO_SENSOR_CONFIRM=true
VITE_DEMO_SENSOR_CONFIRM_DELAY_MS=4000
VITE_ENABLE_DEMO_SENSOR_CONFIRM=true
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
JWT_SECRET_KEY=replace-me-for-demo
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=ecodrop
REDIS_URL=redis://localhost:6379/0
AI_CV_SERVICE_URL=http://localhost:8010
USE_MOCK_AI=true
USE_MOCK_DB=true
COMMAND_MODE=hybrid
DEPOSIT_SESSION_TTL_MINUTES=5
DEVICE_HEARTBEAT_STALE_SECONDS=120
BOTTLE_CONFIDENCE_THRESHOLD=0.65
BOTTLE_MIN_VOLUME_ML=250
BOTTLE_MAX_VOLUME_ML=2000

# AI/CV
AI_CV_MODE=mock
ROBOFLOW_API_KEY=
ROBOFLOW_MODEL_ID=merk-label/1
ROBOFLOW_API_URL=https://detect.roboflow.com
REFERENCE_BOX_HEIGHT_MM=160
REFERENCE_BOX_WIDTH_MM=110

# IoT demo
ECODROP_DEVICE_ID=ECO-SMARTBIN-001
ECODROP_DEVICE_TOKEN=dev-device-token
